<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <absolute-ordering/>

    <!-- Étape 3b : servlet de login OAuth — redirige vers Google -->
    <servlet>
        <servlet-name>OAuthLogin</servlet-name>
        <servlet-class>infres.ws.rest.oauth.OAuthLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OAuthLogin</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Étape 3b : servlet de callback — reçoit le code et récupère le profil -->
    <servlet>
        <servlet-name>OAuthCallback</servlet-name>
        <servlet-class>infres.ws.rest.oauth.OAuthCallbackServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OAuthCallback</servlet-name>
        <url-pattern>/oauth2callback</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>Jersey</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>infres.ws.rest.RestApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>Jersey</servlet-name>
        <url-pattern>/api/*</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
